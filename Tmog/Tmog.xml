						TmogTooltip:Show()
					</OnEnter>
					<OnLeave>
						TmogTooltip:Hide()
					</OnLeave>
					<OnMouseUp>
						if arg1 == "LeftButton" then
							TmogFrame_Toggle()
						end
					</OnMouseUp>
					<OnEvent>
						if event == "PLAYER_LOGIN" then
							this:ClearAllPoints()
							this:SetPoint("CENTER", UIParent, "BOTTOMLEFT", unpack(TMOG_POSITION or {this:GetCenter()}))
						end
					</OnEvent>
