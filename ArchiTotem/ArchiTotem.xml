						this:SetOrientation("VERTICAL")
						this:SetMinMaxValues(0.3, 3.0)
						this:SetValueStep(0.01)
						_G[this:GetName() .. "Low"]:SetText("0.3")
						_G[this:GetName() .. "High"]:SetText("3.0")
						_G[this:GetName() .. "Text"]:SetText("界\n面\n缩\n放")
					</OnLoad>
					<OnShow>
						ArchiTotem_PresetScaleSync()
					</OnShow>
					<OnValueChanged>
						ArchiTotem_PresetScale_OnValueChanged(this:GetValue())
					</OnValueChanged>
				</Scripts>
			</Slider>
			<FontString name="ArchiTotemPresetScaleValue" inherits="GameFontNormal" text="1.00">
				<Anchors>
					<Anchor point="LEFT" relativeTo="ArchiTotemPresetScaleSlider" relativePoint="RIGHT">
						<Offset><AbsDimension x="10" y="0"/></Offset>
					</Anchor>
				</Anchors>
			</FontString>

			<!-- 预设滚动区域 -->
			<ScrollFrame name="ArchiTotemPresetScrollFrame" inherits="UIPanelScrollFrameTemplate" enableMouseWheel="true" hidden="false">
				<Size>
					<AbsDimension x="200" y="160"/>
				</Size>
				<Anchors>
					<Anchor point="TOPLEFT" relativePoint="TOPLEFT">
						<Offset>
							<AbsDimension x="25" y="-240"/>
						</Offset>
					</Anchor>
				</Anchors>
				<Scripts>
					<OnLoad>
						this:EnableMouseWheel(true)
					</OnLoad>
					<OnMouseWheel>
						ArchiTotem_PresetScroll(arg1)
					</OnMouseWheel>
					<OnShow>
						ArchiTotem_ResetPresetScroll(); ArchiTotem_CreatePresetButtons()
					</OnShow>
				</Scripts>
				<ScrollChild>
					<Frame name="ArchiTotemPresetScrollChild">
						<Size>
							<AbsDimension x="200" y="10"/>
						</Size>
						<Anchors>
							<Anchor point="TOPLEFT"/>
						</Anchors>
					</Frame>
				</ScrollChild>
			</ScrollFrame>

			<!-- 向上滚动按钮 -->
			<Button name="ArchiTotemPresetScrollUp" inherits="UIPanelButtonTemplate">
				<Size><AbsDimension x="24" y="24"/></Size>
				<Anchors>
					<Anchor point="TOPLEFT" relativeTo="ArchiTotemPresetScrollFrame" relativePoint="TOPRIGHT">
						<Offset><AbsDimension x="4" y="0"/></Offset>
					</Anchor>
				</Anchors>
				<NormalTexture file="Interface\Buttons\UI-ScrollBar-ScrollUpButton-Up"/>
				<PushedTexture file="Interface\Buttons\UI-ScrollBar-ScrollUpButton-Down"/>
				<DisabledTexture file="Interface\Buttons\UI-ScrollBar-ScrollUpButton-Disabled"/>
				<HighlightTexture file="Interface\Buttons\UI-ScrollBar-ScrollUpButton-Highlight" alphaMode="ADD"/>
				<Scripts>
					<OnClick>ArchiTotem_PresetScroll(1)</OnClick>
				</Scripts>
			</Button>
			<!-- 向下滚动按钮 -->
			<Button name="ArchiTotemPresetScrollDown" inherits="UIPanelButtonTemplate">
				<Size><AbsDimension x="24" y="24"/></Size>
				<Anchors>
					<Anchor point="BOTTOMLEFT" relativeTo="ArchiTotemPresetScrollFrame" relativePoint="BOTTOMRIGHT">
						<Offset><AbsDimension x="4" y="0"/></Offset>
					</Anchor>
				</Anchors>
				<NormalTexture file="Interface\Buttons\UI-ScrollBar-ScrollDownButton-Up"/>
				<PushedTexture file="Interface\Buttons\UI-ScrollBar-ScrollDownButton-Down"/>
				<DisabledTexture file="Interface\Buttons\UI-ScrollBar-ScrollDownButton-Disabled"/>
				<HighlightTexture file="Interface\Buttons\UI-ScrollBar-ScrollDownButton-Highlight" alphaMode="ADD"/>
				<Scripts>
					<OnClick>ArchiTotem_PresetScroll(-1)</OnClick>
				</Scripts>
			</Button>
		</Frames>
		<Layers>
			<Layer level="OVERLAY">
				<FontString name="ArchiTotemPresetListTitle" inherits="GameFontNormal" text="可用预设组合:">
					<Color r="0.9" g="0.9" b="1"/>
					<Anchors>
						<Anchor point="TOPLEFT">
							<Offset>
								<AbsDimension x="25" y="-210"/>
							</Offset>
						</Anchor>
					</Anchors>
				</FontString>
				<FontString name="ArchiTotemPresetHelpText" inherits="GameFontTiny" text="左键: 切换预设 | Shift+左键: 召唤预设">
					<Color r="0.7" g="0.7" b="0.8"/>
					<Anchors>
						<Anchor point="TOPLEFT">
							<Offset>
								<AbsDimension x="25" y="-223"/>
							</Offset>
						</Anchor>
					</Anchors>
				</FontString>
			</Layer>
		</Layers>
	</Frame>
</Ui>
