    <!-- Scroll Bar -->
    <Slider name="IJ_MinimalistScrollBarTemplate" virtual="true">
        <Size>
            <AbsDimension x="16" y="0" />
        </Size>
        <Frames>
            <Button name="$parentScrollUpButton" inherits="IJ_MinimalistScrollUpButtonTemplate">
                <Anchors>
                    <Anchor point="BOTTOM" relativePoint="TOP" />
                </Anchors>
                <Scripts>
                    <OnClick>
                        local parent = this:GetParent()
                        parent:SetValue(parent:GetValue() - (parent:GetHeight() / 4))
                        PlaySound("UChatScrollButton")
                    </OnClick>
                </Scripts>
            </Button>
            <Button name="$parentScrollDownButton" inherits="IJ_MinimalistScrollDownButtonTemplate">
                <Anchors>
                    <Anchor point="TOP" relativePoint="BOTTOM" />
                </Anchors>
                <Scripts>
                    <OnClick>
                        local parent = this:GetParent()
                        parent:SetValue(parent:GetValue() + (parent:GetHeight() / 4))
                        PlaySound("UChatScrollButton")
                    </OnClick>
                </Scripts>
            </Button>
        </Frames>
        <Scripts>
            <OnValueChanged>
                this:GetParent():SetVerticalScroll(arg1)
            </OnValueChanged>
            <OnEnter>
                this.hasLeft = false

                local thumb = getglobal(this:GetName().."ThumbTexture")
                if thumb then
                thumb:SetTexture("Interface\\AddOns\\InstanceJournal\\media\\ui\\minimalist-scrollbar-knob-highlight")
                end
            </OnEnter>
            <OnLeave>
                this.hasLeft = true

                if this.isDragging then
                return
                end

                local thumb = getglobal(this:GetName().."ThumbTexture")
                if thumb then
                thumb:SetTexture("Interface\\AddOns\\InstanceJournal\\media\\ui\\minimalist-scrollbar-knob-up")
                end
            </OnLeave>
            <OnMouseDown>
                this.isDragging = true

                local thumb = getglobal(this:GetName().."ThumbTexture")
                if thumb then
                thumb:SetTexture("Interface\\AddOns\\InstanceJournal\\media\\ui\\minimalist-scrollbar-knob-down")
                end
            </OnMouseDown>
            <OnMouseUp>
                this.isDragging = false

                local thumb = getglobal(this:GetName().."ThumbTexture")
                if thumb and this.hasLeft == false then
                thumb:SetTexture("Interface\\AddOns\\InstanceJournal\\media\\ui\\minimalist-scrollbar-knob-highlight")
                else
                thumb:SetTexture("Interface\\AddOns\\InstanceJournal\\media\\ui\\minimalist-scrollbar-knob-up")
                end
            </OnMouseUp>
        </Scripts>
        <ThumbTexture name="$parentThumbTexture"
            file="Interface\AddOns\InstanceJournal\media\ui\minimalist-scrollbar-knob-up"
            inherits="IJ_MinimalistScrollBarKnob">
            <Size>
                <AbsDimension x="10" y="56" />
            </Size>
        </ThumbTexture>
    </Slider>

