                        <Anchors>
                            <Anchor point="RIGHT">
                                <Offset>
                                    <AbsDimension x="-2" y="0" />
                                </Offset>
                            </Anchor>
                        </Anchors>
                        <NormalTexture
                            file="Interface\AddOns\InstanceJournal\media\ui\ui-searchbar-clear" />
                        <Scripts>
                            <OnEnter>
                                if this:GetNormalTexture() then
                                this:GetNormalTexture():SetAlpha(1.0)
                                end
                            </OnEnter>
                            <OnLeave>
                                if this:GetNormalTexture() then
                                this:GetNormalTexture():SetAlpha(0.5)
                                end
                            </OnLeave>
                            <OnMouseDown>
                                if this:GetButtonState() ~= "DISABLED" and this:GetNormalTexture()
                                then
                                this:GetNormalTexture():ClearAllPoints()
                                this:GetNormalTexture():SetPoint("TOPLEFT", this, "TOPLEFT", 1, -1)
                                this:GetNormalTexture():SetPoint("BOTTOMRIGHT", this, "BOTTOMRIGHT",
                                1, -1)
                                end
                            </OnMouseDown>
                            <OnMouseUp>
                                if this:GetNormalTexture() then
                                this:GetNormalTexture():ClearAllPoints()
                                this:GetNormalTexture():SetAllPoints(this)
                                end
                            </OnMouseUp>
                            <OnClick>
                                local parent = this:GetParent()
                                parent:SetText("")
                                parent:SetFocus()
                                parent:ClearFocus()
                            </OnClick>
                        </Scripts>
                    </Button>
                </Frames>

                <Scripts>
                    <OnLoad>
                        this:SetAutoFocus(false)
                    </OnLoad>
                    <OnEditFocusGained>
                        getglobal(this:GetName() .. "Placeholder"):Hide()
                        getglobal(this:GetName() .. "Icon"):SetAlpha(1.0)

                        if this:GetText() ~= "" and string.len(this:GetText()) >= 3 then
                        if IJ_SearchBar_OnTextChanged then
                        IJ_SearchBar_OnTextChanged(this)
                        end
                        end
                    </OnEditFocusGained>
                    <OnEditFocusLost>
                        if this:GetText() == "" then
                        getglobal(this:GetName() .. "Placeholder"):Show()
                        getglobal(this:GetName() .. "Icon"):SetAlpha(0.5)
                        getglobal(this:GetName() .. "ClearButton"):Hide()
                        else
                        end
                    </OnEditFocusLost>
                    <OnTextChanged>
                        if this:GetText() == "" then
                        getglobal(this:GetName() .. "ClearButton"):Hide()
                        else
                        getglobal(this:GetName() .. "ClearButton"):Show()
                        getglobal(this:GetName() .. "ClearButton"):GetNormalTexture():SetAlpha(0.5)
                        end

                        if IJ_SearchBar_OnTextChanged then
                        IJ_SearchBar_OnTextChanged(this)
                        end
                    </OnTextChanged>
                    <OnEnterPressed>
                        this:ClearFocus()
                    </OnEnterPressed>
                    <OnEscapePressed>
                        this:SetText("")
                        this:ClearFocus()
                        if IJ_SearchDropdown then IJ_SearchDropdown:Hide() end
                    </OnEscapePressed>
                </Scripts>
