    <!-- Up Button -->
    <Button name="IJ_MinimalistScrollUpButtonTemplate" virtual="true">
        <Size>
            <AbsDimension x="16" y="16" />
        </Size>
        <NormalTexture inherits="IJ_MinimalistScrollBarButton"
            file="Interface\AddOns\InstanceJournal\media\ui\minimalist-scrollbar-scrollupbutton-up" />
        <PushedTexture inherits="IJ_MinimalistScrollBarButton"
            file="Interface\AddOns\InstanceJournal\media\ui\minimalist-scrollbar-scrollupbutton-down" />
        <DisabledTexture inherits="IJ_MinimalistScrollBarButton"
            file="Interface\AddOns\InstanceJournal\media\ui\minimalist-scrollbar-scrollupbutton-up" />
        <HighlightTexture inherits="IJ_MinimalistScrollBarButton"
            file="Interface\AddOns\InstanceJournal\media\ui\minimalist-scrollbar-scrollupbutton-highlight" />
        <Scripts>
            <OnLoad>
                local pt = this:GetPushedTexture()
                if pt then
                pt:ClearAllPoints()
                pt:SetPoint("TOPLEFT", 1, -1)
                pt:SetPoint("BOTTOMRIGHT", 1, -1)
                end
            </OnLoad>
            <OnMouseDown>
                local hl = this:GetHighlightTexture()
                if hl then
                hl:SetAlpha(0)
                end
            </OnMouseDown>
            <OnMouseUp>
                local hl = this:GetHighlightTexture()
                if hl then
                hl:SetAlpha(1)
                end
            </OnMouseUp>
        </Scripts>
    </Button>

    <!-- Down Button -->
    <Button name="IJ_MinimalistScrollDownButtonTemplate" virtual="true">
        <Size>
            <AbsDimension x="16" y="16" />
